#!/bin/bash
# Stream the current track title for Waybar with idle detection.
# Shows 󰝚 (music note) when nothing is playing, the track title otherwise.
# Detects any MPRIS player — no --player restriction.

while true; do
    playerctl metadata title 2>/dev/null | while read -r t; do
        if [ -n "$t" ]; then
            echo "$t"
            # Got a title — now stream updates in real time
            playerctl metadata title -F 2>/dev/null | while read -r s; do
                [ -n "$s" ] && echo "$s" || echo "󰝚"
            done
        fi
    done
    echo "󰝚"
    sleep 5
done
